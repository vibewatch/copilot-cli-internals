{"file":"copilot-cli-pkg/app.js","line":8090,"length":86,"truncated":false,"formatted":true,"matchCount":1,"startLine":564105,"endLine":564135,"html":"<pre class=\"astro-code astro-code-themes github-light github-dark\" style=\"--shiki-light:#24292e;--shiki-dark:#e1e4e8;--shiki-light-bg:#fff;--shiki-dark-bg:#24292e; overflow-x: auto;\" tabindex=\"0\" data-language=\"javascript\"><code><span class=\"line\"><span class=\"src-anchor-lineno\">564105</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        set </span><span style=\"--shiki-light:#D73A49;--shiki-dark:#F97583\">--</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">allow</span><span style=\"--shiki-light:#D73A49;--shiki-dark:#F97583\">-</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">all</span><span style=\"--shiki-light:#D73A49;--shiki-dark:#F97583\">-</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">tools.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564106</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564107</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    &#x3C;</span><span style=\"--shiki-light:#005CC5;--shiki-dark:#79B8FF\">mcp-server-name</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">>(tool-name?)</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564108</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        Exactly matches a specific tool from a specific MCP server, or all tools from that server if omitted.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564109</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        The server name is the name of the MCP server as configured in your environment (e.g. \"MyMCP\").</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564110</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        The tool name is the name of the tool as registered with the MCP server (e.g. \"my_tool\").</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564111</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564112</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    url(domain-or-url?)</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564113</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        Matches URL access requests. Applies to the shell and web-fetch tools. If omitted, matches all URLs.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564114</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        Supports exact URLs: \"url(https://github.com)\"</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564115</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        Supports protocol + domain patterns: \"url(https://github.com)\" or \"url(https://*.github.com)\"</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564116</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">        Note: All patterns are protocol-aware. Domains without a protocol default to https://.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564117</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564118</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">  URL Permissions:</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564119</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line line--hit\"><span class=\"src-anchor-lineno\">564120</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">  The --allow-url and --deny-url parameters accept URLs or protocol + domain patterns.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564121</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">  All URL permissions are protocol-aware - approving https://example.com does NOT allow http://example.com.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564122</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">  Patterns without an explicit protocol default to https://.</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564123</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564124</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    # Allow GitHub API access via HTTPS (default)</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564125</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    $ copilot --allow-url=github.com</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564126</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564127</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    # Allow HTTP access explicitly</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564128</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    $ copilot --allow-url=http://example.com</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564129</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564130</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    # Deny access to specific domain over HTTPS</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564131</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    $ copilot --deny-url=https://malicious-site.com</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564132</span><span class=\"src-anchor-linecode\"></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564133</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    # Allow all URLs</span></span></span>\n<span class=\"line\"><span class=\"src-anchor-lineno\">564134</span><span class=\"src-anchor-linecode\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">    $ copilot --allow-all-urls</span></span></span></code></pre>"}